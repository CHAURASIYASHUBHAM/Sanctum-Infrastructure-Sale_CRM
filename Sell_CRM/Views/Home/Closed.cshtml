
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Customer Form</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

    <form method="post" enctype="multipart/form-data">

        <div class="container mt-4 mb-4">
            <div class="card shadow p-4">

                <!-- 1 -->
                <h4 class="text-white p-2 rounded mt-4" style="background-color:#00008B;">
                    1. Customer & Unit Details
                </h4>

                <div class="row mt-3">
                    <div class="col-md-6">
                        <label class="form-label">Customer Name</label>
                        <input type="text" name="CustomerName" class="form-control">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Project / Building</label>
                        <select name="ProjectName" class="form-select">
                            <option>Rivera</option>
                            <option>Sanctum</option>
                            <option>Orbis</option>
                            <option>Gardens</option>
                        </select>
                    </div>

                    <div class="col-md-4 mt-3">
                        <label class="form-label">Flat No.</label>
                        <input type="text" id="flatNo" name="FlatNo" class="form-control">
                    </div>

                    <div class="col-md-4 mt-3">
                        <label class="form-label">Floor / Wing</label>
                        <input type="text" id="floorWing" name="FloorWing" class="form-control">
                    </div>

                    <div class="col-md-4 mt-3">
                        <label class="form-label">Carpet Area</label>
                        <input type="text" id="carpetArea" name="CarpetArea" class="form-control">
                    </div>

                </div>

                <!-- 2 -->
                <h4 class="text-white p-2 rounded mt-4" style="background-color:#00008B;">
                    2. Cost Sheet Details
                </h4>


                <div class="row mt-3">
                    <div class="col-md-4">
                        <label class="form-label">Agreement Value</label>
                        <input type="number" id="agreement" name="AgreementValue" class="form-control">
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Other Charges</label>
                        <input type="number" id="other" name="OtherCharges" class="form-control">
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Total Value</label>
                        <input type="number" id="total" name="TotalConsiderationValue" class="form-control">
                    </div>

                    <div class="col-md-6 mt-3">
                        <label class="form-label">Upload Cost Sheet</label>
                        <input type="file" name="file" class="form-control">
                    </div>
                </div>

                <!-- 3 -->
                <h4 class="text-white p-2 rounded mt-4" style="background-color:#00008B;">
                    Source Details
                </h4>

                <div class="row mt-3">
                    <div class="col-md-4">
                        <label class="form-label">Source Type</label>
                        <select id="sourceType" name="SourceType" class="form-control">
                            <option value="">--Select--</option>
                            <option value="Direct Walk-in">Direct Walk-in</option>
                            <option value="Broker Recommendation">Broker Recommendation</option>
                            <option value="Referral">Referral</option>
                        </select>
                    </div>
                </div>

                <div id="brokerSection" style="display:none;">
                    <h4 class="text-white p-2 rounded mt-4" style="background-color:#00008B;">
                        Broker Details
                    </h4>

                    <div class="row mt-3">
                        <div class="col-md-4">
                            <label>Broker Name</label>
                            <input type="text" name="BrokerName" class="form-control">
                        </div>

                        <div class="col-md-4">
                            <label>Mobile</label>
                            <input type="text" name="BrokerMobileNumber" class="form-control">
                        </div>

                        <div class="col-md-4">
                            <label>Email</label>
                            <input type="email" name="BrokerEmailId" class="form-control">
                        </div>
                    </div>
                </div>

                <div id="referralSection" style="display:none;">
                    <h4 class="text-white p-2 rounded mt-4" style="background-color:#00008B;">
                        Referral Details
                    </h4>

                    <div class="row mt-3">
                        <div class="col-md-6">
                            <label>Referral Name</label>
                            <input type="text" name="ReferralName" class="form-control">
                        </div>

                        <div class="col-md-6">
                            <label>Mobile</label>
                            <input type="text" name="ReferralMobile" class="form-control">
                        </div>
                    </div>
                </div>



                <!-- 4 -->
                <h4 class="text-white p-2 rounded mt-4" style="background-color:#00008B;">
                    4. Promotional Scheme
                </h4>

                <div class="mt-3">

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="mkCheck" name="ModularKitchenType" value="Yes">
                        Modular Kitchen

                        <select id="mkSelect" name="ModularKitchenType" class="form-select mt-2" style="display:none;">
                            <option value="">Select Option</option>
                            <option>Below Counter</option>
                            <option>Full</option>
                            <option>Above Counter</option>
                        </select>
                    </div>

                    <div class="form-check mt-3">
                        <input class="form-check-input" type="checkbox" id="gcCheck">
                        Gold Coin

                        <input type="number" name="GoldCoinAmount"
                               class="form-control mt-2"
                               style="display:none;"
                               id="gc">
                    </div>

                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" name="Television" value="true"> Television
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="AirConditioner" value="true"> Air Conditioner
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="Refrigerator" value="true"> Refrigerator
                    </div>

                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" id="otherCheck">
                        Other

                        <input type="text" name="OtherScheme"
                               class="form-control mt-2"
                               id="otherInput"
                               style="display:none;">
                    </div>

                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" name="NotApplicable" value="true"> Not Applicable
                    </div>

                </div>

                <!-- 5 -->
                <h4 class="text-white p-2 rounded mt-4" style="background-color:#00008B;">
                    5. Brokerage
                </h4>

                <div class="row mt-3">
                    <div class="col-md-4">
                        <label class="form-label">Brokerage %</label>
                        <input type="number" name="BrokeragePercentage" class="form-control">
                    </div>
                </div>

                <button type="submit" class="btn btn-success w-100 mt-4">Submit</button>

            </div>
        </div>

    </form>
    <footer style="background-color:#0d3b66; color:white; text-align:center; padding:10px; position:fixed; bottom:0; width:100%;">
        Developed by Shubham Chaurasiya
    </footer>
    <script src="~/Scripts/jquery-3.7.0.min.js"></script>


    <script>
        $("#flatNo").on("keyup", function () {

            let flat = $(this).val();

            if (flat.length > 0) {

                // 🔹 Remove non-numeric characters
                flat = flat.replace(/\D/g, '');

                let floor = "";


                if (flat.length >= 4) {
                    // 1203 → 12
                    floor = flat.substring(0, 2);
                } else {
                    // 101 → 1
                    floor = flat.charAt(0);
                }

                $("#floorWing").val(floor);


                $.ajax({
                    url: '/Home/GetCarpetArea',
                    type: 'GET',
                    data: { flatNo: flat },
                    success: function (res) {
                        $("#carpetArea").val(res);
                    },
                    error: function () {
                        alert("Error fetching data");
                    }
                });
            }
        });

        $("#mkCheck").change(function () {
            if ($(this).is(":checked")) {
                $("#mkSelect").show();
            } else {
                $("#mkSelect").hide();
                $("#mkSelect").val("");
            }
        });





        $("#gcCheck").change(function () {
            if ($(this).is(":checked")) {
                $("#gc").show();
            } else {
                $("#gc").hide();
                $("#gc").val(""); // reset value
            }
        });

        $("#otherCheck").change(function () {
            if ($(this).is(":checked")) {
                $("#otherInput").show().prop("disabled", false);
            } else {
                $("#otherInput").hide().val("").prop("disabled", true);
            }
        });

        window.onload = function () {
            let today = new Date().toISOString().split('T')[0];
            document.getElementById("dateField").value = today;
        };

        $(document).ready(function () {

            $("#sourceType").change(function () {

                let val = $(this).val();

                // hide sab
                $("#brokerSection").hide();
                $("#referralSection").hide();

                // values clear (important)
                $("#brokerSection input").val('');
                $("#referralSection input").val('');

                if (val === "Broker Recommendation") {
                    $("#brokerSection").show();
                }
                else if (val === "Referral") {
                    $("#referralSection").show();
                }
                // Direct Walk-in → kuch nahi dikhega
            });

        });
    </script>
</body>
</html>