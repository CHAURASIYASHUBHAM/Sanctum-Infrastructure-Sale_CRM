@{
    Layout = null;
}

<style>
    body {
        font-family: Arial;
        background: linear-gradient(135deg,#ff9a9e,#fad0c4);
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
    }

    .box {
        background: white;
        padding: 130px;
        border-radius: 20px;
        width: 320px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    h1 {
        margin-bottom: 20px;
    }

    select, button {
        width: 100%;
        padding: 10px;
        margin-top: 15px;
    }

    button {
        background: #ff6a88;
        color: white;
        border: none;
        cursor: pointer;
    }

        button:hover {
            background: #ff3e6c;
        }
</style>

<div class="box">
    <h1>Sales CRM</h1>

    <form method="post" action="/Home/RedirectPage">
        <select name="type" required>
            <option value="">Select Option</option>
            <option value="Enquiry">Enquiry</option>
            <option value="Closed">Closed</option>
        </select>

        <button>Submit</button>
    </form>
</div>