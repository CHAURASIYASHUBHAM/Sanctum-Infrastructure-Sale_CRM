@model Sell_CRM.Models.CustomerEnquiry
@{
    Layout = null;
}

<style>
    body {
        font-family: 'Segoe UI', Tahoma;
        background: linear-gradient(135deg, #667eea, #764ba2);
        margin: 0;
        padding: 20px;
    }

    .container {
        max-width: 850px;
        margin: auto;
        background: #fff;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    h2 {
        background: linear-gradient(90deg,#4a6cf7,#6a82fb);
        color: white;
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 20px;
    }

    label {
        font-weight: 600;
        margin-top: 10px;
        display: block;
    }

    input, select {
        width: 100%;
        padding: 12px;
        margin-top: 6px;
        border-radius: 8px;
        border: 1px solid #ccc;
        transition: 0.3s;
    }

        input:focus, select:focus {
            border-color: #4a6cf7;
            box-shadow: 0 0 5px rgba(74,108,247,0.5);
            outline: none;
        }

    .error {
        color: red;
        font-size: 12px;
    }

    .btn {
        background: linear-gradient(90deg,#28a745,#218838);
        color: white;
        padding: 12px;
        border: none;
        width: 100%;
        margin-top: 25px;
        border-radius: 8px;
        font-size: 16px;
        transition: 0.3s;
    }

        .btn:hover {
            transform: scale(1.02);
            background: linear-gradient(90deg,#218838,#1e7e34);
        }

    .flex {
        display: flex;
        gap: 8px;
    }

    .email-box span {
        padding: 12px;
        background: #f1f1f1;
        border-radius: 8px;
    }

    hr {
        margin: 25px 0;
    }
</style>

<div class="container">

    @if (TempData["msg"] != null)
    {
        <h3 style="color:green">@TempData["msg"]</h3>
    }

    @using (Html.BeginForm())
    {
        @Html.ValidationSummary(true, "", new { @class = "error" })

        <h2>Customer & Unit Details</h2>

        <label>Customer Name</label>
        @Html.TextBoxFor(m => m.CustomerName, new
        {
            maxlength = "50",
            oninput = "this.value = this.value.replace(/[^A-Za-z ]/g, '')"
        })
        <span class="error">@Html.ValidationMessageFor(m => m.CustomerName)</span>

        <label>Building Name</label>
        @Html.DropDownListFor(m => m.BuildingName,
            new SelectList(new[] { "Building Name", "Rivera", "Sanctum", "Orbis", "Gardens" }))
        <span class="error">@Html.ValidationMessageFor(m => m.BuildingName)</span>

        <label>Mobile</label>
        <div class="flex">
            <select id="countryCode" name="CountryCode" style="max-width:120px;">
                <option value="+91">🇮🇳 +91</option>
                <option value="+1">🇺🇸 +1</option>
                <option value="+44">🇬🇧 +44</option>
                <option value="+971">🇦🇪 +971</option>
                <option value="+61">🇦🇺 +61</option>
            </select>

            @Html.TextBoxFor(m => m.Mobile, new
            {
                maxlength = "10",
                placeholder = "Enter Mobile",
                oninput = "this.value = this.value.replace(/[^0-9]/g,'')"
            })
        </div>
        <span id="mobileError" class="error"></span>
        <span class="error">@Html.ValidationMessageFor(m => m.Mobile)</span>

        <label>Email</label>
        <div class="flex email-box">
            <input type="text" id="emailUser" placeholder="Enter username" oninput="setEmail()" />
            <span>@@gmail.com</span>
        </div>
        <input type="hidden" name="Email" id="Email" />
        <span class="error">@Html.ValidationMessageFor(m => m.Email)</span>

        <label>Configuration</label>
        @Html.DropDownListFor(m => m.Configuration,
            new SelectList(new[] { "1", "2", "3", "1+1 Jodi", "1+2 Jodi", "1 Rk" }),
            "--Select--")
        <span class="error">@Html.ValidationMessageFor(m => m.Configuration)</span>

        <label>Flat No</label>
        @Html.TextBoxFor(m => m.FlatNo, new { type = "number", min = "1" })
        <span class="error">@Html.ValidationMessageFor(m => m.FlatNo)</span>

        <label>Budget</label>
        @Html.DropDownListFor(m => m.Budget,
            new SelectList(new[] {
                "Below 95 Lakh",
                "95 Lakh to 1.5 Crore",
                "Above 1.5 Crore"
            }),
            "--Select Budget--")
        <span class="error">@Html.ValidationMessageFor(m => m.Budget)</span>

        <label>Mode of Payment</label>
        @Html.DropDownListFor(m => m.PaymentMode,
            new SelectList(new[] { "Loan", "Self Funded" }),
            "--Select--")
        <span class="error">@Html.ValidationMessageFor(m => m.PaymentMode)</span>

        <label>Timeline</label>
        @Html.DropDownListFor(m => m.Timeline,
            new SelectList(new[] { "Immediate", "1 Month", "3 Months", "Just Exploring" }),
            "--Select--")
        <span class="error">@Html.ValidationMessageFor(m => m.Timeline)</span>

        <hr />

        <h2>Source Details</h2>

        <label>Source Type</label>
        @Html.DropDownListFor(m => m.SourceType,
     new SelectList(new[] { "Direct Walk-in", "Broker Recommendation", "Referral" }),
     "--Select--",
     new { id = "sourceType" })

        <h3>Broker Details</h3>

        <div id="brokerSection">
            <label>Broker Name</label>
            @Html.TextBoxFor(m => m.BrokerName, new
            {
                oninput = "this.value = this.value.replace(/[^A-Za-z ]/g, '')"
            })

            <label>Broker Mobile</label>
            @Html.TextBoxFor(m => m.BrokerMobile, new
            {
                maxlength = "10",
                oninput = "this.value = this.value.replace(/[^0-9]/g, '')"
            })
        </div>
        <button class="btn">Submit</button>
    }
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $("form").submit(function () {

        let mobile = $("input[name='Mobile']").val();

        // ❌ empty check
        if (!mobile) {
            $("#mobileError").text("Mobile required");
            return false;
        }

        // ❌ 0 se start ya invalid
        if (!/^[1-9][0-9]{9}$/.test(mobile)) {
            $("#mobileError").text("Enter valid mobile (should not start with 0)");
            return false;
        }

        $("#mobileError").text("");

        // ✅ final number (with country code)
        let fullNumber = $("#countryCode").val() + mobile;

        console.log("Final Number:", fullNumber); // +919876543210

    });
    function setEmail() {
        let user = document.getElementById("emailUser").value;
        document.getElementById("Email").value = user ? user + "@@gmail.com" : "";
    }
    $(document).ready(function () {

        function toggleBroker() {
            let source = $("#sourceType").val();

            if (source === "Direct Walk-in") {
                $("#brokerSection").hide();
            } else {
                $("#brokerSection").show();
            }
        }

        // page load pe bhi check
        toggleBroker();

        // change pe bhi
        $("#sourceType").change(function () {
            toggleBroker();
        });
    });

</script>

